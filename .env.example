# ==========================================================================
# Hiring Operations Agent MVP — environment template
#
# Copy this file to `.env` and fill in real values:
#     cp .env.example .env      (PowerShell: Copy-Item .env.example .env)
#
# `.env` is gitignored and MUST NOT be committed. The only real secrets are the
# LLM API keys (OLLAMA_API_KEY / AZURE_OPENAI_API_KEY); every other value is
# non-sensitive local configuration. The MVP has no auth and no database; the
# only third-party service is the cloud LLM (Ollama Cloud or Azure OpenAI).
# You can also set the provider/mode/key at runtime in the UI's "⚙️ LLM
# Settings" panel — those values are held in memory only and reset on restart.
# ==========================================================================

# --------------------------------------------------------------------------
# LLM behaviour
# --------------------------------------------------------------------------
# LLM_MODE selects the primary reasoning path:
#   fallback -> skip the LLM entirely; use the deterministic offline reasoner.
#               This is the UI's "Mock" provider and the default — it runs with
#               no network / no key (offline dev, CI, demos).
#   cloud    -> use the cloud LLM (see LLM_PROVIDER) for all reasoning nodes
LLM_MODE=fallback

# LLM_PROVIDER selects which cloud provider serves the reasoning nodes when
# LLM_MODE=cloud (ignored under the default fallback/"Mock" path):
#   ollama       -> Ollama Cloud (OLLAMA_* below)
#   azure_openai -> Azure OpenAI (AZURE_OPENAI_* below)
LLM_PROVIDER=ollama

# When true, a reasoning node that exhausts its retries against the LLM
# degrades to the deterministic fallback instead of failing the workflow.
# This is the "fallback call when the LLM is unavailable" behaviour.
LLM_FALLBACK_ENABLED=true

# Bounded retry policy for transient LLM/timeout errors (SYSTEM_FLOW §15).
# Heavy reasoning nodes (e.g. evidence-graph construction) can take ~1 min on a
# slow cloud model; a generous timeout avoids a needless timeout+retry.
LLM_TIMEOUT_SECONDS=150
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=2

# --------------------------------------------------------------------------
# Ollama Cloud API  (a real credential — used when LLM_PROVIDER=ollama)
# --------------------------------------------------------------------------
# OLLAMA_HOST is the OpenAI-compatible base URL for Ollama Cloud.
OLLAMA_HOST=https://ollama.com/v1
OLLAMA_MODEL=glm-5.2
OLLAMA_API_KEY=your-ollama-cloud-api-key-here

# --------------------------------------------------------------------------
# Azure OpenAI  (a real credential — used when LLM_PROVIDER=azure_openai)
# --------------------------------------------------------------------------
# The deployment name (not a model id) is used in the request URL; auth is the
# "api-key" header. Leave blank unless you use the Azure provider.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here

# --------------------------------------------------------------------------
# Backend API (FastAPI / Uvicorn)
# --------------------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000

# --------------------------------------------------------------------------
# Frontend (Gradio — Teams chat simulation)
# --------------------------------------------------------------------------
GRADIO_HOST=127.0.0.1
GRADIO_PORT=7860
# Base URL the Gradio UI uses to reach the backend.
BACKEND_BASE_URL=http://127.0.0.1:8000

# --------------------------------------------------------------------------
# Local runtime storage (Local JSON — DB / object-store stand-in)
# The File Watcher monitors RUNTIME_INPUT_DIR for new Meeting Packages.
# --------------------------------------------------------------------------
DATA_DIR=./data
RUNTIME_INPUT_DIR=./data/runtime/input
RUNTIME_PROCESSING_DIR=./data/runtime/processing
RUNTIME_OPERATIONS_DIR=./data/runtime/operations
RUNTIME_APPROVALS_DIR=./data/runtime/approvals
RUNTIME_COMPLETED_DIR=./data/runtime/completed
RUNTIME_LOGS_DIR=./data/runtime/logs
HIRING_TRACKER_PATH=./data/hiring_tracker.json

# --------------------------------------------------------------------------
# File Watcher
# --------------------------------------------------------------------------
# Start the Watchdog file watcher (monitors RUNTIME_INPUT_DIR) when the
# backend runs. Drop a Meeting Package JSON into that folder to trigger a run.
ENABLE_FILE_WATCHER=true

# --------------------------------------------------------------------------
# Mock execution (downstream enterprise integrations are simulated)
# --------------------------------------------------------------------------
# Force one mock adapter to fail so the execution-failure path can be
# exercised. One of: ats | email | teams. Empty = all adapters succeed.
MOCK_EXECUTION_FAIL_ADAPTER=

# --------------------------------------------------------------------------
# Logging (Rich)
# --------------------------------------------------------------------------
LOG_LEVEL=INFO
