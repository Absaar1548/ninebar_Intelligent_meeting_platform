# ==========================================================================
# Hiring Operations Agent MVP — environment template
#
# Copy this file to `.env` and fill in real values:
#     cp .env.example .env      (PowerShell: Copy-Item .env.example .env)
#
# `.env` is gitignored and MUST NOT be committed. Only OLLAMA_API_KEY is a
# real secret; every other value is non-sensitive local configuration.
# The MVP has no auth, no database, and no third-party service besides the
# Ollama Cloud LLM, so no other API keys are required.
# ==========================================================================

# --------------------------------------------------------------------------
# LLM behaviour
# --------------------------------------------------------------------------
# LLM_MODE selects the primary reasoning path:
#   cloud    -> use the Ollama Cloud API for all reasoning nodes (default)
#   fallback -> skip the LLM entirely; use the deterministic fallback path
#               (offline dev, CI, and demos with no network / no key)
LLM_MODE=cloud

# When true, a reasoning node that exhausts its retries against the LLM
# degrades to the deterministic fallback instead of failing the workflow.
# This is the "fallback call when the LLM is unavailable" behaviour.
LLM_FALLBACK_ENABLED=true

# Bounded retry policy for transient LLM/timeout errors (SYSTEM_FLOW §15).
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=2

# --------------------------------------------------------------------------
# Ollama Cloud API  (the only real credential in this file)
# --------------------------------------------------------------------------
# OLLAMA_HOST is the OpenAI-compatible base URL for Ollama Cloud.
OLLAMA_HOST=https://ollama.com/v1
OLLAMA_MODEL=glm-5.2
OLLAMA_API_KEY=your-ollama-cloud-api-key-here

# --------------------------------------------------------------------------
# Backend API (FastAPI / Uvicorn)
# --------------------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000

# --------------------------------------------------------------------------
# Frontend (Gradio — Teams chat simulation)
# --------------------------------------------------------------------------
GRADIO_HOST=127.0.0.1
GRADIO_PORT=7860
# Base URL the Gradio UI uses to reach the backend.
BACKEND_BASE_URL=http://127.0.0.1:8000

# --------------------------------------------------------------------------
# Local runtime storage (Local JSON — DB / object-store stand-in)
# The File Watcher monitors RUNTIME_INPUT_DIR for new Meeting Packages.
# --------------------------------------------------------------------------
DATA_DIR=./data
RUNTIME_INPUT_DIR=./data/runtime/input
RUNTIME_PROCESSING_DIR=./data/runtime/processing
RUNTIME_OPERATIONS_DIR=./data/runtime/operations
RUNTIME_APPROVALS_DIR=./data/runtime/approvals
RUNTIME_COMPLETED_DIR=./data/runtime/completed
RUNTIME_LOGS_DIR=./data/runtime/logs
HIRING_TRACKER_PATH=./data/hiring_tracker.json

# --------------------------------------------------------------------------
# Mock execution (downstream enterprise integrations are simulated)
# --------------------------------------------------------------------------
# Force one mock adapter to fail so the execution-failure path can be
# exercised. One of: ats | email | teams. Empty = all adapters succeed.
MOCK_EXECUTION_FAIL_ADAPTER=

# --------------------------------------------------------------------------
# Logging (Rich)
# --------------------------------------------------------------------------
LOG_LEVEL=INFO
